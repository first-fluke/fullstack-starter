{
  "$schema": "./hook-variant.schema.json",
  "vendor": "commandcode",
  "hookDir": ".commandcode/hooks",
  "settingsFile": ".commandcode/settings.json",
  "projectDirEnv": null,
  "runtime": "bun",
  "events": {
    "SessionStart": [
      {
        "hook": "serena-primer.ts",
        "timeout": 3
      },
      {
        "hook": "state-boundary.ts",
        "timeout": 5
      }
    ],
    "Stop": {
      "hook": "persistent-mode.ts",
      "timeout": 5
    }
  }
}
